        else { sample(); for (let i = 0; i < sIdx.length; i++) { psx[i] = sx[i]; psy[i] = sy[i]; } if (reduce) draw(); }   // running: re-fit only; keep the wake/ground (no intro replay)
      }
      ctx.fillStyle = '#fff'; ctx.fillRect(0, 0, W, H);
    }

    const init = () => {                                   // CONSTELLATION ENTRY plays, then hands off to the run loop + wake
      phase = 'entry';
      cancelAnimationFrame(raf); size(); last = 0;         // size() -> setupEntry() (phase === 'entry')
      raf = requestAnimationFrame(frame);
    };
    let to; window.addEventListener('resize', () => { clearTimeout(to); to = setTimeout(() => { if (ready) size(); }, 160); });   // re-fit only; never re-enter the intro
    stage.addEventListener('pointermove', (e) => { const r = stage.getBoundingClientRect(); mX = e.clientX - r.left; mY = e.clientY - r.top; mOn = true; });
    stage.addEventListener('pointerleave', () => { mOn = false; });
    window.__sim = (m) => { cancelAnimationFrame(raf); let ms = 0; last = 0; for (let q = 0; q < m; q++) { ms += 16.7; const T = ms / 1000; let dt = T - last; last = T; step(dt); } return 'stepped ' + m + ' phase=' + phase; }; // TEMP verify (removed in final cleanup)
    window.__asm = () => { cancelAnimationFrame(raf); flyin ? setupAssembly() : setupEntry(); return 'reset to entry'; }; // TEMP verify
  }
</script>
