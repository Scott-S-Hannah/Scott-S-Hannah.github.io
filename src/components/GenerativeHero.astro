---
/* Generative hero (v4-loose, 2D canvas). Persistent teal particles stream in
   and chase a 6-phase run cycle (public/run/phase0..5.png) with long trails and
   index-based matching, so the runner reads as flowing energy that runs more
   than a hard silhouette. White base, Helvetica/Swiss, teal #02ABBF.
   Exploratory, not locked. Next: WebGL + GSAP ScrollTrigger. */
---
<section class="gh">
  <header class="gh__nav">
    <span class="gh__brand">Dr. Scott Hannah</span>
    <nav class="gh__links" aria-label="Primary">
      <a href="#">Research</a>
      <a href="#">Work</a>
      <a href="#">Contact</a>
      <span class="gh__dot" aria-hidden="true"></span>
    </nav>
  </header>
  <div class="gh__stage" id="gh-stage">
    <canvas id="gh-canvas"></canvas>
    <div class="gh__ovl">
      <div class="gh__id">
        <h1 class="gh__name">Dr. Scott<br>Hannah<span>.</span></h1>
        <p class="gh__role">Exercise Physiologist</p>
        <p class="gh__org">University of Winchester</p>
        <p class="gh__lede">I measure how the body responds to exercise, effort, and recovery, for elite sport and clinical care.</p>
      </div>
    </div>
  </div>
</section>

<style>
  .gh { min-height: 100vh; display: flex; flex-direction: column; background: #fff; color: #0a0a0b; font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif; }
  .gh__nav { display: flex; align-items: center; justify-content: space-between; padding: 18px 32px; border-bottom: 1px solid #ededed; }
  .gh__brand { font-weight: 700; letter-spacing: -0.02em; font-size: 15px; }
  .gh__links { display: flex; gap: 22px; align-items: center; font-size: 11px; letter-spacing: 0.1em; color: #71717a; text-transform: uppercase; }
  .gh__links a { color: #71717a; text-decoration: none; }
  .gh__links a:hover { color: #0a0a0b; }
  .gh__dot { width: 7px; height: 7px; border-radius: 50%; background: #02abbf; }
  .gh__stage { position: relative; flex: 1; overflow: hidden; }
  #gh-canvas { position: absolute; inset: 0; width: 100%; height: 100%; display: block; }
  .gh__ovl { position: absolute; inset: 0; display: flex; align-items: center; padding: 0 32px; pointer-events: none; }
  .gh__id { width: 44%; }
  .gh__name { font-weight: 700; font-size: clamp(40px, 6.4vw, 86px); line-height: 0.84; letter-spacing: -0.045em; margin: 0; }
  .gh__name span { color: #02abbf; }
  .gh__role { font-size: clamp(14px, 1.4vw, 18px); font-weight: 500; margin: 18px 0 0; }
  .gh__org { font-size: 13px; color: #71717a; margin: 2px 0 0; }
  .gh__lede { font-size: clamp(12px, 1.1vw, 14px); line-height: 1.55; color: #26262a; max-width: 24em; margin: 18px 0 0; }
  @media (max-width: 760px) { .gh__id { width: 84%; } .gh__ovl { align-items: flex-start; padding-top: 36px; } }
</style>

<script>
  const canvas = document.getElementById('gh-canvas');
  const stage = document.getElementById('gh-stage');
  if (canvas && stage) {
    const ctx = canvas.getContext('2d');
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const NPH = 6, K = 2200, DPP = 9;
    let W = 0, H = 0, DPR = 1, raf = 0, gf = 0, ready = false;
    let parts = [], clouds = [], edges = [];
    const imgs = [];

    const srcPoint = () => ({ x: -W * 0.05 + Math.random() * W * 0.26, y: H * 0.1 + Math.random() * H * 0.8 });

    function samplePhase(img) {
      const sw = 240, sh = Math.max(1, Math.round(sw * img.naturalHeight / img.naturalWidth));
      const off = document.createElement('canvas'); off.width = sw; off.height = sh;
      const o = off.getContext('2d');
      o.fillStyle = '#fff'; o.fillRect(0, 0, sw, sh); o.drawImage(img, 0, 0, sw, sh);
      const d = o.getImageData(0, 0, sw, sh).data;
      const fig = (x, y) => { if (x < 0 || y < 0 || x >= sw || y >= sh) return false; const k = (y * sw + x) * 4; return d[k] * 0.299 + d[k + 1] * 0.587 + d[k + 2] * 0.114 < 150; };
      const pts = [];
      for (let j = 0; j < sh; j++) for (let i = 0; i < sw; i++) {
        if (fig(i, j)) {
          const edge = !fig(i - 2, j) || !fig(i + 2, j) || !fig(i, j - 2) || !fig(i, j + 2);
          pts.push([i / sw, j / sh, edge ? 1 : 0]);
        }
      }
      return pts;
    }

    function buildClouds() {
      const raw = imgs.map(samplePhase);
      let minx = 1, miny = 1, maxx = 0, maxy = 0;
      for (const pts of raw) for (const p of pts) { if (p[0] < minx) minx = p[0]; if (p[0] > maxx) maxx = p[0]; if (p[1] < miny) miny = p[1]; if (p[1] > maxy) maxy = p[1]; }
      const uw = (maxx - minx) || 1, uh = (maxy - miny) || 1, uar = uw / uh;
      let bh = H * 0.86, bw = bh * uar;
      if (bw > W * 0.5) { bw = W * 0.5; bh = bw / uar; }
      const fx = W - bw - W * 0.06, fy = (H - bh) / 2;
      clouds = []; edges = [];
      for (const pts of raw) {
        pts.sort((a, b) => (Math.floor(a[1] * 44) - Math.floor(b[1] * 44)) || (a[0] - b[0]));
        const cloud = new Float32Array(K * 2), eg = new Uint8Array(K), n = pts.length || 1;
        for (let i = 0; i < K; i++) {
          const p = pts[Math.min(n - 1, Math.floor(i / K * n))] || [0.5, 0.5, 0];
          cloud[i * 2] = fx + ((p[0] - minx) / uw) * bw;
          cloud[i * 2 + 1] = fy + ((p[1] - miny) / uh) * bh;
          eg[i] = p[2] || 0;
        }
        clouds.push(cloud); edges.push(eg);
      }
      parts = [];
      for (let i = 0; i < K; i++) { const s = srcPoint(); parts.push({ x: s.x, y: s.y, vx: 0, vy: 0, t0: Math.random() * 190 }); }
    }

    function size() {
      DPR = Math.min(window.devicePixelRatio || 1, 2);
      const r = stage.getBoundingClientRect(); W = r.width; H = r.height;
      canvas.width = W * DPR; canvas.height = H * DPR;
      ctx.setTransform(DPR, 0, 0, DPR, 0, 0);
      ctx.fillStyle = '#fff'; ctx.fillRect(0, 0, W, H);
      gf = 0;
      if (ready) { buildClouds(); if (reduce) renderStatic(); }
    }

    let t = 0;
    const ang = (x, y) => { const s = 0.0017; return (Math.sin(x * s + t * 0.6) + Math.cos(y * s - t * 0.42) + Math.sin((x + y) * s * 0.5 + t * 0.22)) * Math.PI; };

    function renderStatic() {
      ctx.fillStyle = '#fff'; ctx.fillRect(0, 0, W, H);
      ctx.fillStyle = 'rgba(2,171,191,0.72)';
      const c = clouds[0];
      for (let i = 0; i < K; i++) ctx.fillRect(c[i * 2], c[i * 2 + 1], 1.6, 1.6);
    }

    function frame() {
      t += 0.007; gf++;
      ctx.fillStyle = 'rgba(255,255,255,0.36)'; ctx.fillRect(0, 0, W, H);
      const pt = gf / DPP, curr = Math.floor(pt) % NPH, next = (curr + 1) % NPH, fr = pt - Math.floor(pt);
      const c0 = clouds[curr], c1 = clouds[next];
      ctx.fillStyle = 'rgba(2,171,191,0.9)';
      ctx.strokeStyle = 'rgba(2,171,191,0.33)'; ctx.lineWidth = 1; ctx.beginPath();
      for (let i = 0; i < K; i++) {
        const p = parts[i];
        if (gf < p.t0) continue;
        const hx = c0[i * 2] + (c1[i * 2] - c0[i * 2]) * fr;
        const hy = c0[i * 2 + 1] + (c1[i * 2 + 1] - c0[i * 2 + 1]) * fr;
        const px = p.x, py = p.y;
        const dx = hx - p.x, dy = hy - p.y, dist = Math.sqrt(dx * dx + dy * dy) || 1;
        const a = ang(p.x, p.y);
        if (dist > 50) {
          const inv = 1 / dist;
          p.vx += dx * inv * 2.6 + Math.cos(a) * 0.5; p.vy += dy * inv * 2.6 + Math.sin(a) * 0.5;
          p.vx *= 0.72; p.vy *= 0.72; p.x += p.vx; p.y += p.vy;
          ctx.moveTo(px, py); ctx.lineTo(p.x, p.y);
        } else {
          p.vx += dx * 0.42 + Math.cos(a) * 0.1; p.vy += dy * 0.42 + Math.sin(a) * 0.1;
          p.vx *= 0.72; p.vy *= 0.72; p.x += p.vx; p.y += p.vy;
          if (edges[curr][i]) ctx.fillRect(p.x - 0.4, p.y - 0.4, 2.4, 2.4);
          else ctx.fillRect(p.x, p.y, 1.5, 1.5);
        }
        if (Math.random() < 0.0018) { const s = srcPoint(); p.x = s.x; p.y = s.y; p.vx = 0; p.vy = 0; }
      }
      ctx.stroke();
      raf = requestAnimationFrame(frame);
    }

    const init = () => { cancelAnimationFrame(raf); size(); if (!reduce) frame(); };
    let loaded = 0;
    const oneDone = () => { loaded++; if (loaded === NPH) { ready = true; init(); } };
    for (let i = 0; i < NPH; i++) { const im = new Image(); im.onload = oneDone; im.onerror = oneDone; im.src = '/run/phase' + i + '.png'; imgs.push(im); }
    let to; window.addEventListener('resize', () => { clearTimeout(to); to = setTimeout(init, 150); });
  }
</script>
