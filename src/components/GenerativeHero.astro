---
/* Generative hero. A real Mixamo run cycle (from baking/running.fbx) is BAKED offline to a
   compact file (public/runner-bake.json: 531 node positions over 36 frames + the static
   topology, ~190KB). The runtime plays it back on a 2D canvas with NO three.js: each frame
   lerps the baked positions into world space and projects side-on (Z=horizontal, Y=vertical,
   X=depth). The wireframe is the model's REAL faces vertex-clustered onto grid-cell nodes
   (a properly connected mesh); translucent depth-shaded face fills give form + shorts; the
   figure sheds posterior nodes as a trailing energy wake. Entry: a static poster (28KB webp,
   also the no-JS / reduced-motion / load-error fallback) crossfades into the running figure.
   White base, single teal #02ABBF, Helvetica/Swiss. Re-bake instructions: baking/README.md. */
---
<section class="gh">
  <header class="gh__nav">
    <span class="gh__brand">Dr. Scott Hannah</span>
    <span class="gh__status"><span class="gh__dot" aria-hidden="true"></span>Open to collaboration</span>
  </header>
  <div class="gh__stage" id="gh-stage">
    <canvas id="gh-canvas" aria-hidden="true"></canvas>
    <img id="gh-poster" class="gh__poster" src="/hero-poster.webp" width="1500" height="651" decoding="async" alt="Dr. Scott Hannah rendered as a teal low-poly running figure" />
    <div class="gh__ovl">
      <div class="gh__id">
        <h1 class="gh__name">Dr. Scott<br>Hannah<span>.</span></h1>
        <p class="gh__role">Exercise Physiologist</p>
        <p class="gh__org">University of Winchester</p>
        <p class="gh__lede">I measure how the body responds to exercise, effort, and recovery, for elite sport and clinical care.</p>
      </div>
    </div>
  </div>
</section>

<style>
  .gh { min-height: 100vh; display: flex; flex-direction: column; background: #fff; color: #0a0a0b; font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif; }
  .gh__nav { display: flex; align-items: center; justify-content: space-between; padding: 18px 32px; border-bottom: 1px solid #ededed; }
  .gh__brand { font-weight: 700; letter-spacing: -0.02em; font-size: 15px; }
  .gh__status { display: flex; gap: 9px; align-items: center; font-size: 11px; letter-spacing: 0.1em; color: #71717a; text-transform: uppercase; }
  .gh__dot { width: 7px; height: 7px; border-radius: 50%; background: #02abbf; }
  .gh__stage { position: relative; flex: 1; overflow: hidden; }
  #gh-canvas { position: absolute; inset: 0; width: 100%; height: 100%; display: block; }
  .gh__poster { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: contain; object-position: right center; pointer-events: none; opacity: 1; transition: opacity 0.6s ease; }
  .gh__poster.is-hidden { opacity: 0; }
  @media (prefers-reduced-motion: reduce) { .gh__poster { transition: none; } }
  .gh__ovl { position: absolute; inset: 0; display: flex; align-items: flex-end; padding: 0 clamp(40px, 5vw, 76px) 7vh; pointer-events: none; }   /* generous frame; wordmark on the shared baseline with the runner */
  .gh__id { width: 44%; }
  .gh__name { font-weight: 700; font-size: clamp(44px, 7.8vw, 108px); line-height: 0.82; letter-spacing: -0.046em; margin: 0; }   /* name leads: prominent wordmark */
  .gh__name span { color: #02abbf; }
  .gh__role { font-size: clamp(14px, 1.4vw, 18px); font-weight: 500; margin: 18px 0 0; }
  .gh__org { font-size: 13px; color: #71717a; margin: 2px 0 0; }
  .gh__lede { font-size: clamp(12px, 1.1vw, 14px); line-height: 1.55; color: #26262a; max-width: 24em; margin: 18px 0 0; }
  @media (max-width: 760px) { .gh__id { width: 84%; } .gh__ovl { align-items: flex-start; padding-top: 36px; } .gh__poster { object-position: center bottom; } }
</style>

<script>
  const canvas = document.getElementById('gh-canvas');
  const stage = document.getElementById('gh-stage');
  const poster = document.getElementById('gh-poster');   // static fallback (no-JS / load-error / first paint); crossfaded out once the live canvas renders
  if (canvas && stage) {
    const ctx = canvas.getContext('2d');
    let posterUp = true;
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const BODY = '2,171,191', CORE = '2,108,122';

    let W = 0, H = 0, DPR = 1, raf = 0, last = 0, ready = false;
    let frames = null, wpos = null, nFrames = 0, cycleDur = 1, TS = 0.5, clipT = 0;   // baked run cycle: per-frame node world positions, played back (TS = original mixer.timeScale)
    let sIdx = [];                                  // node identity list (one per grid cell node); sIdx[i] === i
    let edges = [];                                 // [a,b,restLen3D]  real-mesh edges (vertex-clustered) -> drawn wireframe lines
    let faces = null;                               // node triples = the model's real faces collapsed onto the cells (properly connected, fillable)
    let wireKeep = 0.6;                              // fraction of wireframe edges drawn (lines only; fill uses all faces) -> thins the mesh look (~old kNN line density)
    // per-sample buffers
    let sx = null, sy = null, sz = null, psx = null, psy = null; // screen + prev
    let bb = null, sc = 1, ox = 0, oy = 0;          // model-space bbox + screen fit

    // ENERGY WAKE: the wireframe sheds its own nodes off the posterior (back + legs); each detached node
    // FLOWS off as a tapered trailing streak, with a few tumbling edge shards for the wireframe-coming-apart
    // character. Streams left toward the name, fades before the text, reacts to the cursor, clears the figure.
    let groundY = 0, haveGround = false, planted = false, plantX = 0, plantY = 0, plantAge = 1, tflow = 0;
    let bxMin = 0, bxMax = 0, byMin = 0, byMax = 0, cx = 0;   // body bbox + centroid (set in sample)
    let mX = -1, mY = -1, mOn = false;
    // CONSTELLATION ENTRY: the hero opens as a field of floating points (a proximity network); the points
    // stream in and lock onto the runner as it runs left -> right to its final spot, then it sheds the wake.
    let phase = 'entry';                                 // 'entry' (constellation) | 'running'
    let cT = 0; const ENTRY_DUR = 3.2, BUILD_WIN = 0.24;  // kinetic-light entry: light streams from the name and the runner constructs bottom-up (per-node build window)
    const flyin = new URLSearchParams(location.search).get('entry') !== 'stream';   // DEFAULT = build + travel from the name (mesh self-construction); ?entry=stream -> the light-stream variant
    let rv = null, asmT = 0; const ASM_DUR = 3.2, ASM_DX = 0.42, RV_WIN = 0.16;   // fly-in: per-node build order (graph dist from feet) + length + run-in
    let cArr = null, cStag = null;                       // per-node crystallisation 0..1 + inflow-start stagger
    let bord = null, sox = null, soy = null, szNorm = null, emitX = 0, emitY = 0;   // construction-from-name: build order (feet->head), per-node source/emitter positions, depth, emitter point beside the wordmark
    let enHX = null, enHY = null, enHead = null; const EN_HIST = 8;   // inflow light-trails (accretion arcs): per-node ring buffer of recent positions
    let NPIECE = 0, introDX0 = 0, pc = null;             // NPIECE/pc come from the bake (regions); unused by the entry but kept
    // PERSISTENT AMBIENT FIELD: a sparse, near-static "survey lattice" in the negative space around the runner that lives
    // for the whole session (not just the 3.6s entry); same teal depth ramp as the figure; one shared breath; lifted by the wake.
    let latN = 0, latX = null, latY = null, latT = null, latEdges = null, wakeEnergy = 0;
    let tris = null, triRest = null, triWy = null, triGd = null;   // mesh faces + rest size + per-face height (0=feet..1=head) + graph-dist-from-feet (for the shorts band)
    let shLo = 0.39, shHi = 0.57, shGArm = 0.66;         // SHORTS: world-height band mid-thigh -> waistband; shGArm excludes arms/hands that dip to that height
    // posterior emission picker: a body-node index biased to the BACK third (low x) + LEGS (high y),
    // suppressing the forward upper body. Shared by all styles; must run after sample().
    function pickPosterior() {
      const n = sIdx.length, bw = (bxMax - bxMin) || 1, bh = (byMax - byMin) || 1;
      let k = (Math.random() * n) | 0;
      for (let tries = 0; tries < 8; tries++) {
        const c = (Math.random() * n) | 0;
        const fxn = (sx[c] - bxMin) / bw, fyn = (sy[c] - byMin) / bh;
        const isLegs = fyn > 0.55, isBack = fxn < 0.34, frontUpper = (fxn > 0.5 && fyn < 0.55);
        if ((isLegs || isBack) && !frontUpper) { k = c; break; } k = c;
      }
      return k;
    }

    // === SHED: the wireframe sheds its own nodes + short edge shards off the back ===
    const shN = 560;
    const shX = new Float32Array(shN), shY = new Float32Array(shN), shVX = new Float32Array(shN), shVY = new Float32Array(shN);
    const shL = new Float32Array(shN), shDr = new Float32Array(shN), shTone = new Float32Array(shN), shSeed = new Float32Array(shN);
    const shKind = new Uint8Array(shN), shFdx = new Float32Array(shN), shFdy = new Float32Array(shN), shSpin = new Float32Array(shN);
    const SH_HIST = 13;                                  // per-particle trail length so the shed parts FLOW off
    const shHX = new Float32Array(shN * SH_HIST), shHY = new Float32Array(shN * SH_HIST), shHead = new Uint8Array(shN), shCnt = new Uint8Array(shN);
    let shEmitAcc = 0, shedPulse = 0;                    // shedPulse spikes at toe-off so the wake breathes with the stride
    const SH_NEMIT = 40; const shEmit = new Int32Array(SH_NEMIT); let shEmitRot = 0, shEmitRefresh = 0;   // limited, slowly-migrating spawn positions -> distinct streams, less uniform clumping
    const SH_DRIFT = 128, SH_LIFT = 5, SH_CURL = 24, SH_RELAX = 0.075, SH_EMIT = 104, SH_FRAG_FRAC = 0.10, SH_LIFE_MIN = 5.8, SH_LIFE_VAR = 4.0, SH_VMAX = 290;
    function seedShed() { shEmitAcc = 0; for (let i = 0; i < shN; i++) { shL[i] = 0; shVX[i] = 0; shVY[i] = 0; shKind[i] = 0; shX[i] = -100; shY[i] = -100; shCnt[i] = 0; shHead[i] = 0; shSeed[i] = Math.random() * 6.2832; } for (let j = 0; j < SH_NEMIT; j++) shEmit[j] = pickPosterior(); }


    // Load the pre-baked run cycle (compact: per-frame node positions + static topology) -> no three.js, no 35MB FBX at runtime.
    // Reduced-motion: skip the load entirely; the static poster is the hero.
    if (!reduce) fetch('/runner-bake.json').then(r => { if (!r.ok) throw new Error('bake ' + r.status); return r.json(); }).then(d => {
      const dec = (s, Ctor) => { const bin = atob(s), u = new Uint8Array(bin.length); for (let i = 0; i < bin.length; i++) u[i] = bin.charCodeAt(i); return new Ctor(u.buffer); };
      const n = d.n; nFrames = d.F; cycleDur = d.dur; TS = d.ts; NPIECE = d.NPIECE; bb = d.bb;
      const q = dec(d.pos, Uint16Array), qb = d.qbb;
      frames = new Float32Array(nFrames * n * 3);
      for (let k = 0; k < frames.length; k++) { const a = k % 3, lo = qb[a]; frames[k] = lo + q[k] / 65535 * (qb[a + 3] - lo); }   // dequantize world positions
      const ea = dec(d.ea, Uint16Array), eb = dec(d.eb, Uint16Array), er = dec(d.er, Float32Array);
      edges = []; for (let e = 0; e < ea.length; e++) edges.push([ea[e], eb[e], er[e]]);
      faces = new Int32Array(dec(d.fc, Uint16Array)); tris = faces; triRest = dec(d.trS, Float32Array);
      const tW = dec(d.tW, Uint8Array), tG = dec(d.tG, Uint8Array);
      triWy = new Float32Array(tW.length); triGd = new Float32Array(tG.length);
      for (let i = 0; i < tW.length; i++) { triWy[i] = tW[i] / 255; triGd[i] = tG[i] / 255; }
      pc = new Int16Array(dec(d.pc, Uint16Array));
      sIdx = Array.from({ length: n }, (_, i) => i);
      sx = new Float32Array(n); sy = new Float32Array(n); sz = new Float32Array(n); psx = new Float32Array(n); psy = new Float32Array(n); wpos = new Float32Array(n * 3);
      ready = true; init();
    }).catch(e => { console.error('hero: bake load failed', e); });

    const smooth = (e0, e1, x) => { const u = Math.max(0, Math.min(1, (x - e0) / (e1 - e0))); return u * u * (3 - 2 * u); };

    function fit() {                                 // model bbox -> figure box (right on desktop; lower-centre on mobile to clear the headline)
      const mw = bb.maxz - bb.minz, mh = bb.maxy - bb.miny;   // side profile: Z=horizontal, Y=vertical, X=depth
      const mobile = W < 760;
      const targetH = H * (mobile ? 0.50 : 0.78); sc = targetH / mh;   // figure supports the name (not competing)
      const figW = mw * sc;
      if (mobile) {                                   // centred and sat at the bottom, below the stacked text
        ox = (W - figW) / 2 - bb.minz * sc;
        oy = H - H * 0.03 + bb.miny * sc;             // y flips: screenY = oy - worldY*sc
      } else {
        ox = W - figW - W * 0.085 - bb.minz * sc;
        oy = H * 0.93 + bb.miny * sc;                 // stand the runner on the baseline (feet near the bottom), not floating centred
      }
    }

    function getNodePositions() {                      // lerp the baked run cycle (clipT) into wpos[node*3 + x/y/z]
      const N = sIdx.length, fp = (((clipT / cycleDur) % 1) + 1) % 1 * nFrames, fa = Math.floor(fp), t = fp - fa, fb = (fa + 1) % nFrames, ba = fa * N * 3, bbo = fb * N * 3;
      for (let k = 0, m = N * 3; k < m; k++) wpos[k] = frames[ba + k] + (frames[bbo + k] - frames[ba + k]) * t;
    }
    function sample() {
      getNodePositions();
      bxMin = 1e9; bxMax = -1e9; byMin = 1e9; byMax = -1e9; let sxSum = 0;
      for (let i = 0; i < sIdx.length; i++) {
        psx[i] = sx[i]; psy[i] = sy[i];
        const wx = wpos[i * 3], wy = wpos[i * 3 + 1], wz = wpos[i * 3 + 2];   // project: screenX = world z, screenY = -world y, depth = world x
        sx[i] = ox + wz * sc; sy[i] = oy - wy * sc; sz[i] = wx; sxSum += sx[i];
        if (sx[i] < bxMin) bxMin = sx[i]; if (sx[i] > bxMax) bxMax = sx[i];
        if (sy[i] < byMin) byMin = sy[i]; if (sy[i] > byMax) byMax = sy[i];
      }
      cx = sxSum / sIdx.length;                         // body centroid x (stable back-line reference)
    }

    const TIERS = 7;
    const M = [127, 216, 225], Bc = [2, 171, 191], C = [2, 108, 122];   // mist -> body -> core
    const col = (t) => { let r, g, b; if (t < 0.5) { const u = t * 2; r = M[0] + (Bc[0] - M[0]) * u; g = M[1] + (Bc[1] - M[1]) * u; b = M[2] + (Bc[2] - M[2]) * u; } else { const u = (t - 0.5) * 2; r = Bc[0] + (C[0] - Bc[0]) * u; g = Bc[1] + (C[1] - Bc[1]) * u; b = Bc[2] + (C[2] - Bc[2]) * u; } return `${r | 0},${g | 0},${b | 0}`; };

    // GLOW POINTS: the reference's crisp-core + soft-echo luminous point, translated to a WHITE bg.
    // On black, additive light = glow; on white the dual is SUBTRACTIVE, so each point is ink: a wide
    // faint MIST-teal echo (drawn under 'multiply', easing paper toward teal, never mud) beneath a tight
    // CORE-teal crisp core (source-over). Two 64px sprites baked once; every point is two drawImage blits.
    const makeSprite = (stops) => { const c = document.createElement('canvas'); c.width = c.height = 64; const g = c.getContext('2d'); const rg = g.createRadialGradient(32, 32, 0, 32, 32, 32); for (const [st, cl] of stops) rg.addColorStop(st, cl); g.fillStyle = rg; g.fillRect(0, 0, 64, 64); return c; };
    const SPR_SOFT = makeSprite([[0.0, 'rgba(120,210,222,0.46)'], [0.35, 'rgba(127,216,225,0.22)'], [1.0, 'rgba(127,216,225,0.0)']]);   // wide defocused depth-bloom (multiply) — the soft teal halo
    const SPR_CRISP = makeSprite([[0.0, 'rgba(2,108,122,0.92)'], [0.14, 'rgba(2,124,138,0.86)'], [0.32, 'rgba(2,171,191,0.30)'], [0.6, 'rgba(2,171,191,0.05)'], [1.0, 'rgba(2,171,191,0.0)']]);   // sharp luminous deep-teal core (source-over)
    const gpX = new Float32Array(700), gpY = new Float32Array(700), gpD = new Float32Array(700), gpA = new Float32Array(700), gpS = new Float32Array(700);
    const asmRev = new Float32Array(700);                   // fly-in: per-node placed-ness (drives fills + vertices building from the feet up)
    const hsh = (i) => { const x = Math.sin(i * 78.233 + 1.3) * 43758.5453; return x - Math.floor(x); };   // stable per-index 0..1 (for size variation)
    function drawGlowField(n, X, Y, D, A, S) {              // X,Y,D(depth 0..1),A(fade),S(size mult) accessors. Two batched passes = two composite switches, never per point.
      for (let i = 0; i < n; i++) { gpX[i] = X(i); gpY[i] = Y(i); gpD[i] = D(i); gpA[i] = A(i); gpS[i] = S ? S(i) : 1; }
      ctx.globalCompositeOperation = 'multiply';            // echo pass (soft teal halo / depth bloom)
      for (let i = 0; i < n; i++) { const a = gpA[i]; if (a <= 0.004) continue; const d = gpD[i], rE = (1.5 + 1.4 * d) * gpS[i] * 2.8, aE = (0.62 + 0.38 * d) * 0.42 * a; if (aE <= 0.004) continue; ctx.globalAlpha = aE; ctx.drawImage(SPR_SOFT, gpX[i] - rE, gpY[i] - rE, rE * 2, rE * 2); }
      ctx.globalCompositeOperation = 'source-over';         // crisp pass (the luminous core)
      for (let i = 0; i < n; i++) { const a = gpA[i]; if (a <= 0.006) continue; const d = gpD[i], rC = (1.5 + 1.4 * d) * gpS[i], aC = (0.64 + 0.36 * d) * a; ctx.globalAlpha = aC; ctx.drawImage(SPR_CRISP, gpX[i] - rC, gpY[i] - rC, rC * 2, rC * 2); }
      ctx.globalAlpha = 1;
    }

    function seedLattice() {                               // sparse persistent field in the negative space around the runner (right of the text on desktop; off on mobile for now)
      const rnd = (i, s) => { const x = Math.sin((i + 1) * 12.9898 + s * 78.233) * 43758.5453; return x - Math.floor(x); };
      latN = W < 760 ? 0 : 92;
      latX = new Float32Array(latN); latY = new Float32Array(latN); latT = new Float32Array(latN);
      for (let i = 0; i < latN; i++) { latX[i] = (0.44 + 0.54 * rnd(i, 11)) * W; latY[i] = (0.08 + 0.86 * rnd(i, 12)) * H; latT[i] = rnd(i, 13); }   // right of the .gh__id column; depth 0..1 (mist..core)
      const le = [], maxD2 = (Math.min(W, H) * 0.18) ** 2;   // k=2 nearest links, built once
      for (let i = 0; i < latN; i++) { let n1 = -1, n2 = -1, d1 = 1e18, d2 = 1e18; for (let j = 0; j < latN; j++) { if (j === i) continue; const dx = latX[i] - latX[j], dy = latY[i] - latY[j], d = dx * dx + dy * dy; if (d < d1) { d2 = d1; n2 = n1; d1 = d; n1 = j; } else if (d < d2) { d2 = d; n2 = j; } } if (n1 > i && d1 < maxD2) le.push(i, n1); if (n2 > i && d2 < maxD2) le.push(i, n2); }
      latEdges = new Int32Array(le);
    }
    function drawLattice(gFade) {                          // one shared slow breath, depth-toned with the figure's own ramp, faded out over the left text column
      if (!latN || gFade <= 0.001) return;
      const sway = Math.sin(tflow * 0.22) * 1.6, sway2 = Math.cos(tflow * 0.17) * 1.0, lift = 1 + wakeEnergy * 0.5;
      const fx0 = W * 0.30, fx1 = W * 0.45, maxL2 = (Math.min(W, H) * 0.21) ** 2;
      ctx.strokeStyle = `rgba(${BODY},${(0.075 * gFade).toFixed(3)})`; ctx.beginPath();   // links (single batched stroke)
      for (let e = 0; e < latEdges.length; e += 2) { const a = latEdges[e], b = latEdges[e + 1], ax = latX[a] + sway * latT[a], ay = latY[a] + sway2 * latT[a], bx = latX[b] + sway * latT[b], by = latY[b] + sway2 * latT[b], dx = ax - bx, dy = ay - by; if (dx * dx + dy * dy > maxL2 || (ax < fx0 && bx < fx0)) continue; ctx.moveTo(ax, ay); ctx.lineTo(bx, by); }
      ctx.stroke();
      ctx.save();                                          // glow points: shared breath + a small per-point drift (alive but restrained)
      drawGlowField(latN,
        i => latX[i] + sway * latT[i] + Math.sin(tflow * 0.48 + latT[i] * 6.2832 + i * 0.7) * 0.7,
        i => latY[i] + sway2 * latT[i] + Math.cos(tflow * 0.416 + (latT[i] * 6.2832 + i * 0.7) * 1.3) * 0.7,
        i => latT[i],
        i => gFade * lift * smooth(fx0, fx1, latX[i] + sway * latT[i]),
        i => 0.7 + 0.95 * hsh(i + 131));                     // varied ambient point sizes
      ctx.restore();
    }

    function draw() {
      if (posterUp && poster) { posterUp = false; poster.classList.add('is-hidden'); }   // first live frame -> crossfade the static poster out
      ctx.fillStyle = '#fff'; ctx.fillRect(0, 0, W, H);
      if (haveGround) {                                  // ground line: anchors the runner, binds figure to the name
        const gy = groundY + 3, grad = ctx.createLinearGradient(0, 0, W, 0);   // full-width baseline: the shared ground the wordmark AND runner stand on (present under the name, not just the figure)
        grad.addColorStop(0, `rgba(${BODY},0.16)`); grad.addColorStop(0.4, `rgba(${BODY},0.20)`); grad.addColorStop(1, `rgba(${BODY},0.40)`);
        ctx.strokeStyle = grad; ctx.lineWidth = 1; ctx.beginPath(); ctx.moveTo(0, gy); ctx.lineTo(W, gy); ctx.stroke();
      }
      if (haveGround && plantAge < 0.5) { const a = 0.15 * (1 - plantAge / 0.5); ctx.fillStyle = `rgba(${CORE},${a.toFixed(3)})`; ctx.beginPath(); ctx.ellipse(plantX, plantY + 2, 26, 5, 0, 0, 6.2832); ctx.fill(); }
      drawShed();
      drawFills(null);                                       // translucent region plates (form/shading + shorts) under the wireframe
      const z0 = bb.minx, zr = (bb.maxx - bb.minx) || 1;     // depth axis = X
      ctx.lineWidth = DPR <= 1 ? 1.25 : 1.0;
      // edges: far -> near, each tier toned + faded by depth (far = pale/faint, near = deep/bold)
      for (let tier = 0; tier < TIERS; tier++) {
        const t = (tier + 0.5) / TIERS, za0 = z0 + zr * tier / TIERS, za1 = z0 + zr * (tier + 1) / TIERS;
        ctx.strokeStyle = `rgba(${col(t)},${(0.28 + 0.5 * t).toFixed(3)})`;
        ctx.beginPath();
        for (let e = 0; e < edges.length; e++) {
          if ((e * 0.618034) % 1 >= wireKeep) continue;   // stable, evenly-spread edge thinning
          const a = edges[e][0], b = edges[e][1], za = (sz[a] + sz[b]) * 0.5;
          if (za < za0 || za >= za1) continue;
