---
const partners = ['English National Ballet', 'Saracens', 'Queens Park Rangers', 'Marathon des Sables', 'NHS Stroke Services'];
---
<section class="trust">
  <div class="container">
    <p class="label">Applied practice</p>
    <p class="trust__lede">Physiological assessment and rehabilitation science, delivered to elite sport and clinical partners through WinWell.</p>
    <ul class="trust__list">
      {partners.map((p) => <li>{p}</li>)}
    </ul>
  </div>
</section>

<style>
  .trust { background: #efeae1; border-block: 1px solid var(--line); padding-block: clamp(2.5rem, 2rem + 3vw, 4rem); }
  .trust__lede { font-size: var(--step-1); color: var(--ink-soft); max-width: 36ch; margin-top: 0.8rem; line-height: 1.45; }
  .trust__list { list-style: none; padding: 0; margin-top: 1.4rem; display: flex; flex-wrap: wrap; gap: 0.6rem 1.6rem; font-size: var(--step-0); color: var(--ink-soft); }
</style>
