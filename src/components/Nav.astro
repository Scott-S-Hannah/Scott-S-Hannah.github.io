---
const links = [
  { href: '/#focus', label: 'Work' },
  { href: '/publications', label: 'Publications' },
  { href: '/#about', label: 'About' },
];
---
<header class="nav">
  <div class="container nav__inner">
    <a class="nav__brand" href="/">Scott Hannah<span aria-hidden="true">.</span></a>
    <nav class="nav__links" aria-label="Primary">
      {links.map((l) => <a href={l.href}>{l.label}</a>)}
      <a class="nav__cta" href="/#contact">Get in touch</a>
    </nav>
  </div>
</header>

<style>
  .nav { border-bottom: 1px solid var(--line); }
  .nav__inner { display: flex; align-items: center; justify-content: space-between; padding-block: 1.1rem; }
  .nav__brand { font-family: var(--font-display); font-weight: 800; font-size: 1.05rem; color: var(--ink); letter-spacing: -0.01em; }
  .nav__brand span { color: var(--teal); }
  .nav__links { display: flex; align-items: center; gap: 1.4rem; font-size: var(--step--1); }
  .nav__links a { color: var(--mut); }
  .nav__links a:hover { color: var(--ink); }
  .nav__cta { background: var(--ink); color: var(--paper) !important; border-radius: 999px; padding: 0.5rem 1rem; }
  .nav__cta:hover { background: var(--teal-deep); }
  @media (max-width: 34rem) { .nav__links { gap: 0.9rem; } .nav__links a:not(.nav__cta) { display: none; } }
</style>
